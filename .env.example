# ==== Google Generative AI ====
# API key lấy từ Google AI Studio (https://aistudio.google.com/apikey) — free tier.
GOOGLE_API_KEY=your-google-api-key

# Tên model Gemini dùng để sinh câu trả lời (free tier: gemini-2.0-flash).
GEMINI_MODEL=gemini-2.0-flash

# ==== Firebase ====
# Đường dẫn tới file service account JSON.
# Để trống nếu chạy trên môi trường có Application Default Credentials (vd: Cloud Run).
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# ==== Vector store (ChromaDB) ====
# Thư mục persist dữ liệu ChromaDB.
CHROMA_DIR=./chroma_data

# ==== RAG ====
# Số sản phẩm gần nhất lấy ra cho mỗi câu hỏi.
TOP_K=5
