# ==== Google Generative AI ====
# API key lấy từ Google AI Studio (https://aistudio.google.com/apikey) — free tier.
GOOGLE_API_KEY=your-google-api-key

# Tên model Gemini dùng để sinh câu trả lời.
# Free tier RPD (request/ngày) chênh nhau nhiều: gemini-2.5-flash ~20/ngày,
# gemini-3.1-flash-lite ~500/ngày (hợp để test), gemma-4-31b-it ~1500 nhưng kém ổn định.
# Xem hạn mức thật của key tại https://aistudio.google.com.
GEMINI_MODEL=gemini-3.1-flash-lite

# Model tạo embedding (kiểm tra bằng list_models nếu key không hỗ trợ tên này).
EMBEDDING_MODEL=models/gemini-embedding-001

# ==== Firebase ====
# Đường dẫn tới file service account JSON.
# Để trống nếu chạy trên môi trường có Application Default Credentials (vd: Cloud Run).
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# ==== Vector store (ChromaDB) ====
# Thư mục persist dữ liệu ChromaDB.
CHROMA_DIR=./chroma_data

# ==== RAG ====
# Số sản phẩm gần nhất lấy ra cho mỗi câu hỏi.
TOP_K=5

# Ngưỡng khoảng cách cosine tối đa để coi là "liên quan" (0..2, nhỏ = giống hơn).
# Xa hơn ngưỡng bị loại -> tránh trả sản phẩm rác khi không có gì khớp.
RELEVANCE_MAX_DISTANCE=0.33
